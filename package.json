{
  "name": "electron-shadcn",
  "productName": "ElectronShadCNTemplate",
  "appId": "electron.shadcn.template",
  "version": "1.0.0",
  "description": "Electron Builder with shadcn-ui (Vite + Typescript)",
  "main": "./out/main/index.js",
  "author": "Axiom",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite dev",
    "build": "electron-vite build",
    "release": "electron-builder --config electron-builder.config.ts",
    "build:release": "npm run build && npm run release",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test:dom": "vitest run --config vitest.dom.config.ts",
    "test:dom:watch": "vitest --config vitest.dom.config.ts",
    "test:unit": "vitest run --config vitest.main.config.ts",
    "test:unit:watch": "vitest --config vitest.main.config.ts",
    "test:e2e": "playwright test",
    "test:all": "npm run test:dom && npm run test:unit && npm run test:e2e",
    "db:push": "npx drizzle-kit push",
    "db:generate": "npx drizzle-kit generate"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@eslint/compat": "^1.2.9",
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/semver": "^7.7.1",
    "drizzle-kit": "^0.31.8",
    "electron": "^36.4.0",
    "electron-builder": "^26.4.0",
    "electron-playwright-helpers": "^1.7.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.1",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vite": "^6.3.5",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@icons-pack/react-simple-icons": "^12.7.0",
    "@libsql/client": "^0.15.15",
    "@orpc/client": "^1.13.13",
    "@orpc/server": "^1.13.13",
    "@radix-ui/react-navigation-menu": "^1.2.10",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-toggle": "^1.1.6",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.77.1",
    "@tanstack/react-router": "^1.120.20",
    "@tanstack/router-devtools": "^1.117.1",
    "@vitejs/plugin-react": "^4.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "i18next": "^25.0.1",
    "immer": "^10.1.1",
    "lucide-react": "^0.503.0",
    "ollama": "^0.6.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.3",
    "semver": "^7.7.4",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.10"
  }
}
