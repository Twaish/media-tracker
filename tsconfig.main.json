{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out/main",
    "paths": {
      "@/*": ["./electron/main/*"],
      "@domain/*": ["./electron/main/domain/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["./electron/main/**/*", "./shared/**/*"],
  "exclude": ["./electron/main/tests/**/*"]
}
